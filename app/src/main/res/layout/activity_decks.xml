<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FAFAFA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Title and Filter -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="My Decks"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/black"/>
                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:layout_alignParentEnd="true"
                    android:background="@drawable/social_icon_bg"
                    android:padding="8dp"
                    android:src="@android:drawable/ic_menu_sort_by_size"/>
            </RelativeLayout>

            <!-- Search Bar -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="20dp"
                android:background="@drawable/rounded_edittext_white"
                android:gravity="center_vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">
                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@android:drawable/ic_menu_search"
                    app:tint="@color/gray_text"/>
                <EditText
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@null"
                    android:hint="Search your study decks..."
                    android:textSize="14sp"
                    android:layout_marginStart="8dp"
                    android:inputType="text"/>
            </LinearLayout>

            <!-- Chips -->
            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:scrollbars="none">
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="✓ All Decks"
                        android:textColor="@color/white"
                        android:background="@drawable/rounded_chip_blue"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:textStyle="bold"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Biology"
                        android:textColor="@color/black"
                        android:background="@drawable/rounded_chip_white"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginStart="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Geography"
                        android:textColor="@color/black"
                        android:background="@drawable/rounded_chip_white"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginStart="10dp"/>
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Astronomy"
                        android:textColor="@color/black"
                        android:background="@drawable/rounded_chip_white"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="8dp"
                        android:layout_marginStart="10dp"/>
                </LinearLayout>
            </HorizontalScrollView>

            <!-- Decks List -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="20dp">

                <!-- Cellular Biology -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon1" android:layout_width="50dp" android:layout_height="50dp" android:background="@color/icon_blue_bg" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_help" app:tint="@color/primary_blue"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cellular Biology" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon1" app:layout_constraintTop_toTopOf="@id/icon1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="124 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t1" app:layout_constraintTop_toBottomOf="@id/t1"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon1" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="85%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb1" app:layout_constraintBottom_toBottomOf="@+id/pb1" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb1" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="85" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon1"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- World Capitals -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon2" android:layout_width="50dp" android:layout_height="50dp" android:background="@color/icon_green_bg" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_mapmode" app:tint="@color/primary_green"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="World Capitals" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon2" app:layout_constraintTop_toTopOf="@id/icon2"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="56 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t2" app:layout_constraintTop_toBottomOf="@id/t2"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon2" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="42%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb2" app:layout_constraintBottom_toBottomOf="@+id/pb2" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb2" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="42" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon2"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- Star Constellations -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon3" android:layout_width="50dp" android:layout_height="50dp" android:background="@color/icon_purple_bg" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/btn_star_big_on" app:tint="#9C27B0"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Star Constellations" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon3" app:layout_constraintTop_toTopOf="@id/icon3"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="32 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t3" app:layout_constraintTop_toBottomOf="@id/t3"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon3" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="92%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb3" app:layout_constraintBottom_toBottomOf="@+id/pb3" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb3" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="92" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon3"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- Organic Chemistry -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon4" android:layout_width="50dp" android:layout_height="50dp" android:background="@color/icon_orange_bg" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_edit" app:tint="@color/progress_orange"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Organic Chemistry" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon4" app:layout_constraintTop_toTopOf="@id/icon4"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="88 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t4" app:layout_constraintTop_toBottomOf="@id/t4"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon4" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="15%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb4" app:layout_constraintBottom_toBottomOf="@+id/pb4" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb4" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="15" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon4"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- Ancient History -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon5" android:layout_width="50dp" android:layout_height="50dp" android:background="@color/icon_gray_bg" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_gallery" app:tint="@color/gray_text"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ancient History" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon5" app:layout_constraintTop_toTopOf="@id/icon5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="45 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t5" app:layout_constraintTop_toBottomOf="@id/t5"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon5" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="67%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb5" app:layout_constraintBottom_toBottomOf="@+id/pb5" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb5" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="67" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon5"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>

                <View android:layout_width="match_parent" android:layout_height="16dp"/>

                <!-- European Art -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp" app:cardElevation="0dp">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:padding="16dp" android:background="@drawable/rounded_card_bg">
                        <FrameLayout android:id="@+id/icon6" android:layout_width="50dp" android:layout_height="50dp" android:background="#FCE4EC" app:layout_constraintStart_toStartOf="parent" app:layout_constraintTop_toTopOf="parent">
                            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:layout_gravity="center" android:src="@android:drawable/ic_menu_camera" app:tint="@color/progress_pink"/>
                        </FrameLayout>
                        <TextView android:id="@+id/t6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="European Art" android:textSize="18sp" android:textStyle="bold" android:textColor="@color/black" android:layout_marginStart="16dp" app:layout_constraintStart_toEndOf="@id/icon6" app:layout_constraintTop_toTopOf="@id/icon6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="72 Cards" android:textSize="13sp" android:textColor="@color/gray_text" app:layout_constraintStart_toStartOf="@id/t6" app:layout_constraintTop_toBottomOf="@id/t6"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Mastery Progress" android:textSize="12sp" android:textColor="@color/gray_text" android:layout_marginTop="16dp" app:layout_constraintTop_toBottomOf="@id/icon6" app:layout_constraintStart_toStartOf="parent"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30%" android:textSize="12sp" android:textStyle="bold" android:textColor="@color/black" app:layout_constraintTop_toTopOf="@+id/pb6" app:layout_constraintBottom_toBottomOf="@+id/pb6" app:layout_constraintEnd_toEndOf="parent" android:layout_marginBottom="16dp"/>
                        <ProgressBar android:id="@+id/pb6" style="?android:attr/progressBarStyleHorizontal" android:layout_width="match_parent" android:layout_height="6dp" android:layout_marginTop="32dp" android:progress="30" android:progressDrawable="@drawable/custom_progress_bar" app:layout_constraintTop_toBottomOf="@id/icon6"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </androidx.cardview.widget.CardView>


            </LinearLayout>

        </LinearLayout>
    </ScrollView>

    <!-- FAB -->
    <Button
        android:layout_width="wrap_content"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:text="+ Create Deck"
        android:textAllCaps="false"
        android:textColor="@color/white"
        android:textStyle="bold"
        android:background="@drawable/rounded_button_blue"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toTopOf="@id/bottomNavigation"
        app:layout_constraintEnd_toEndOf="parent"
        android:paddingHorizontal="24dp"/>

    <!-- Bottom Navigation Mockup -->
    <LinearLayout
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:background="@color/white"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout android:id="@+id/navHome" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_today"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HOME" android:textSize="10sp" android:textColor="@color/gray_text"/>
        </LinearLayout>

        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_compass"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="WHATSHOT" android:textSize="10sp"/>
        </LinearLayout>

        <View
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/circle_border_blue"
            android:backgroundTint="#3370FD"
            android:foreground="@android:drawable/ic_input_add" />

        <LinearLayout android:id="@+id/navStyle" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_manage" app:tint="@color/primary_blue"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="STYLE" android:textSize="10sp" android:textColor="@color/primary_blue"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/navProfile" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@android:drawable/ic_menu_myplaces"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PERSON" android:textSize="10sp"/>
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
